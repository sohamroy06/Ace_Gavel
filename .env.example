# ===========================================================
# Gavel Environment Variables
# ===========================================================
# Copy this file to .env and fill in your values.
# All values here override config.yaml when set.
# ===========================================================

# --- REQUIRED ---

# Admin dashboard password
ADMIN_PASSWORD=change-this-before-deploying

# Flask secret key (use a long random string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-long-random-string

# PostgreSQL connection string (from Supabase)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Redis connection string (from Upstash)
# Format: rediss://default:password@host:port
REDIS_URL=rediss://default:your-password@your-redis.upstash.io:6379

# --- OPTIONAL ---

# Set to 'true' to disable email (recommended for initial setup)
DISABLE_EMAIL=true

# Email configuration (only needed if DISABLE_EMAIL is false)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# EMAIL_FROM=your-email@gmail.com
# EMAIL_AUTH_MODE=tls

# SendGrid (alternative to SMTP)
# USE_SENDGRID=true
# SENDGRID_API_KEY=your-sendgrid-api-key

# Base URL for the application (optional)
# BASE_URL=https://your-app.up.railway.app

# Reverse proxy mode (default: true for Railway)
# PROXY=true

# Skip config.yaml entirely (use only env vars)
# IGNORE_CONFIG_FILE=true

# Minimum views before smart assignment (default: 2)
# MIN_VIEWS=2

# Judge timeout in minutes (default: 5.0)
# TIMEOUT=5.0

# Telemetry (default: true)
# SEND_STATS=true
